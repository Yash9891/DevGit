# -----------------------------------------------------------------------------
# WHAT IS OOP?
# -----------------------------------------------------------------------------
# OOP (Object-Oriented Programming) is a way of writing code by modelling
# real-world things as "objects".
#
# Instead of writing functions and variables everywhere, you group related
# data and behaviour together inside a CLASS.
#
# Real-world analogy:
#   A "Car" is a class (blueprint).
#   Your specific red Honda City is an OBJECT (instance of the class).
#   colour, speed, brand  → attributes (data the object holds)
#   drive(), brake()      → methods   (things the object can do)
#
# 4 Pillars of OOP:
#   1. Encapsulation  — bundle data + methods, hide internal details
#   2. Inheritance    — a child class reuses code from a parent class
#   3. Polymorphism   — same method name, different behaviour per class
#   4. Abstraction    — show only what is necessary, hide the rest


# =============================================================================
# 1. CLASS AND OBJECT
# =============================================================================

# ── Define a class ────────────────────────────────────────────────────────────
# A class is a BLUEPRINT. It defines what attributes and methods objects will have.

class Dog:
    # __init__ is the constructor — called automatically when object is created
    # 'self' refers to the object being created (like 'this' in other languages)
    def __init__(self, name, breed, age):
        self.name  = name    # instance attribute
        self.breed = breed
        self.age   = age

    def bark(self):
        print(f"{self.name} says: Woof!")

    def info(self):
        print(f"Name: {self.name} | Breed: {self.breed} | Age: {self.age}")


# ── Create objects (instances) ────────────────────────────────────────────────
dog1 = Dog("Bruno",  "Labrador", 3)
dog2 = Dog("Sheru",  "Pomeranian", 5)
dog3 = Dog("Tommy",  "German Shepherd", 2)

# Access attributes
print(dog1.name)     # Bruno
print(dog2.breed)    # Pomeranian

# Call methods
dog1.bark()          # Bruno says: Woof!
dog2.info()          # Name: Sheru | Breed: Pomeranian | Age: 5

# Every object is independent
dog1.name = "Max"    # change dog1 only
print(dog1.name)     # Max
print(dog2.name)     # Sheru  — unchanged

# Check the type
print(type(dog1))    # <class '__main__.Dog'>
print(isinstance(dog1, Dog))   # True


# =============================================================================
# 2. __init__ METHOD (Constructor)
# =============================================================================
# __init__ runs AUTOMATICALLY when you create an object.
# Use it to set up the initial state (attributes) of the object.
# 'self' is always the first parameter — Python passes the object automatically.

class Student:
    def __init__(self, name, age, marks):
        self.name  = name
        self.age   = age
        self.marks = marks

    def grade(self):
        if self.marks >= 90:
            return "A+"
        elif self.marks >= 75:
            return "A"
        elif self.marks >= 60:
            return "B"
        else:
            return "C"

    def display(self):
        print(f"Student : {self.name}")
        print(f"Age     : {self.age}")
        print(f"Marks   : {self.marks}")
        print(f"Grade   : {self.grade()}")
        print()

s1 = Student("Yash",     20, 92)
s2 = Student("Prashant", 21, 78)
s3 = Student("Rohit",    19, 55)

s1.display()
s2.display()
s3.display()


# =============================================================================
# 3. CLASS ATTRIBUTE vs INSTANCE ATTRIBUTE
# =============================================================================
# Instance attribute → unique to each object  (defined inside __init__)
# Class attribute    → shared by ALL objects  (defined outside __init__)

class Circle:
    pi = 3.14159   # class attribute — same for every Circle object

    def __init__(self, radius):
        self.radius = radius   # instance attribute — different per object

    def area(self):
        return Circle.pi * self.radius ** 2

    def circumference(self):
        return 2 * Circle.pi * self.radius


c1 = Circle(5)
c2 = Circle(10)

print(c1.area())            # 78.53975
print(c2.area())            # 314.159
print(Circle.pi)            # 3.14159  — access via class name
print(c1.pi)                # 3.14159  — also accessible via instance


# =============================================================================
# 4. METHODS — Types
# =============================================================================

class BankAccount:
    bank_name = "Python Bank"   # class attribute

    def __init__(self, owner, balance=0):
        self.owner   = owner
        self.balance = balance

    # ── Instance method — works on a specific object, needs 'self' ────────────
    def deposit(self, amount):
        self.balance += amount
        print(f"Deposited ₹{amount}. New balance: ₹{self.balance}")

    def withdraw(self, amount):
        if amount > self.balance:
            print("Insufficient balance!")
        else:
            self.balance -= amount
            print(f"Withdrew ₹{amount}. New balance: ₹{self.balance}")

    def show_balance(self):
        print(f"{self.owner}'s balance: ₹{self.balance}")

    # ── Class method — works on the class itself, not a specific object ───────
    # Decorated with @classmethod. Receives 'cls' (the class) instead of 'self'
    @classmethod
    def get_bank_name(cls):
        return cls.bank_name

    @classmethod
    def change_bank_name(cls, new_name):
        cls.bank_name = new_name

    # ── Static method — doesn't need self or cls, just a utility function ─────
    # Decorated with @staticmethod. No automatic first argument.
    @staticmethod
    def is_valid_amount(amount):
        return amount > 0


# Using the BankAccount class
acc1 = BankAccount("Yash", 1000)
acc2 = BankAccount("Prashant", 5000)

acc1.deposit(500)        # Deposited ₹500. New balance: ₹1500
acc1.withdraw(200)       # Withdrew ₹200. New balance: ₹1300
acc2.show_balance()      # Prashant's balance: ₹5000

print(BankAccount.get_bank_name())           # Python Bank
BankAccount.change_bank_name("PyBank")
print(BankAccount.get_bank_name())           # PyBank

print(BankAccount.is_valid_amount(100))      # True
print(BankAccount.is_valid_amount(-50))      # False


# =============================================================================
# 5. ENCAPSULATION — hiding internal data
# =============================================================================
# Encapsulation means bundling data and methods together, and restricting
# direct access to some details.
#
# Python naming convention:
#   self.name      → public     (accessible everywhere)
#   self._name     → protected  (convention: "don't use outside the class")
#   self.__name    → private    (name-mangled — hard to access from outside)

class Person:
    def __init__(self, name, age, salary):
        self.name      = name       # public
        self._age      = age        # protected
        self.__salary  = salary     # private

    def get_salary(self):           # getter — controlled access
        return self.__salary

    def set_salary(self, amount):   # setter — controlled modification
        if amount > 0:
            self.__salary = amount
            print(f"Salary updated to ₹{self.__salary}")
        else:
            print("Salary must be positive!")

    def display(self):
        print(f"{self.name} | Age: {self._age} | Salary: ₹{self.__salary}")


p = Person("Yash", 20, 50000)

print(p.name)          # Yash          ✅ public — accessible directly
print(p._age)          # 20            ⚠️  protected — accessible but discouraged
# print(p.__salary)    # ❌ AttributeError — private, not directly accessible

print(p.get_salary())  # 50000         ✅ use getter method
p.set_salary(60000)                    # ✅ use setter method
p.display()


# ── @property — Pythonic way to make getters/setters ─────────────────────────
class Temperature:
    def __init__(self, celsius):
        self.__celsius = celsius

    @property
    def celsius(self):              # getter — access like an attribute
        return self.__celsius

    @celsius.setter
    def celsius(self, value):       # setter — validate before setting
        if value < -273.15:
            print("Temperature below absolute zero is not possible!")
        else:
            self.__celsius = value

    @property
    def fahrenheit(self):           # read-only computed property
        return (self.__celsius * 9/5) + 32


t = Temperature(25)
print(t.celsius)       # 25           ← looks like attribute, calls getter
print(t.fahrenheit)    # 77.0
t.celsius = 100        # calls setter
print(t.celsius)       # 100
t.celsius = -300       # Temperature below absolute zero is not possible!


# =============================================================================
# 6. INHERITANCE — reusing code from a parent class
# =============================================================================
# Inheritance lets a child class get all attributes and methods of a parent class.
# The child can also add NEW methods or OVERRIDE existing ones.
#
# Syntax:   class ChildClass(ParentClass):

# ── Parent class ──────────────────────────────────────────────────────────────
class Animal:
    def __init__(self, name, sound):
        self.name  = name
        self.sound = sound

    def speak(self):
        print(f"{self.name} says {self.sound}!")

    def eat(self):
        print(f"{self.name} is eating.")


# ── Child classes ──────────────────────────────────────────────────────────────
class Dog(Animal):
    def __init__(self, name):
        super().__init__(name, "Woof")   # super() calls the parent __init__

    def fetch(self):                     # new method, only in Dog
        print(f"{self.name} fetches the ball!")


class Cat(Animal):
    def __init__(self, name):
        super().__init__(name, "Meow")

    def purr(self):
        print(f"{self.name} purrs...")


class Lion(Animal):
    def __init__(self, name):
        super().__init__(name, "Roar")

    def speak(self):    # OVERRIDE parent method
        print(f"The mighty {self.name} ROARS loudly!")


dog  = Dog("Bruno")
cat  = Cat("Whiskers")
lion = Lion("Simba")

dog.speak()     # Bruno says Woof!
cat.speak()     # Whiskers says Meow!
lion.speak()    # The mighty Simba ROARS loudly!  ← overridden

dog.eat()       # Bruno is eating.   ← inherited from Animal
dog.fetch()     # Bruno fetches the ball!  ← Dog-only method
cat.purr()      # Whiskers purrs...

# Check inheritance
print(isinstance(dog, Dog))     # True
print(isinstance(dog, Animal))  # True  — Dog IS an Animal
print(issubclass(Dog, Animal))  # True


# ── Multi-level inheritance ───────────────────────────────────────────────────
class Vehicle:
    def __init__(self, brand):
        self.brand = brand

    def start(self):
        print(f"{self.brand} engine started.")


class Car(Vehicle):
    def __init__(self, brand, model):
        super().__init__(brand)
        self.model = model

    def drive(self):
        print(f"Driving {self.brand} {self.model}.")


class ElectricCar(Car):
    def __init__(self, brand, model, battery):
        super().__init__(brand, model)
        self.battery = battery

    def charge(self):
        print(f"Charging {self.brand} {self.model} ({self.battery} kWh battery).")


tesla = ElectricCar("Tesla", "Model 3", 75)
tesla.start()    # Tesla engine started.   ← from Vehicle
tesla.drive()    # Driving Tesla Model 3.  ← from Car
tesla.charge()   # Charging Tesla Model 3 (75 kWh battery). ← from ElectricCar


