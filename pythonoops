# 7. POLYMORPHISM — same method, different behaviour
# =============================================================================
# Polymorphism means "many forms".
# The same method name behaves differently depending on the object calling it.

class Shape:
    def area(self):
        pass   # to be overridden

class Rectangle(Shape):
    def __init__(self, l, w):
        self.l, self.w = l, w

    def area(self):
        return self.l * self.w

class Triangle(Shape):
    def __init__(self, base, height):
        self.base   = base
        self.height = height

    def area(self):
        return 0.5 * self.base * self.height

class Circle(Shape):
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        return 3.14159 * self.radius ** 2


# Same function works on every shape — this is polymorphism
def print_area(shape):
    print(f"Area: {shape.area():.2f}")

shapes = [Rectangle(4, 5), Triangle(6, 8), Circle(7)]

for s in shapes:
    print_area(s)
# Area: 20.00
# Area: 24.00
# Area: 153.94


# ── Duck typing — Python's flexible polymorphism ──────────────────────────────
# "If it walks like a duck and quacks like a duck, it's a duck."
# Python doesn't check the TYPE — only whether the method EXISTS.

class Printer:
    def print_doc(self):
        print("Printer is printing a document.")

class Scanner:
    def print_doc(self):
        print("Scanner is displaying a scan.")

class PDF:
    def print_doc(self):
        print("PDF viewer is rendering a page.")

devices = [Printer(), Scanner(), PDF()]

for device in devices:
    device.print_doc()   # same call, completely different behaviour


# =============================================================================
# 8. ABSTRACTION — hide complexity, show only essentials
# =============================================================================
# An abstract class is a "template" — it defines WHAT methods must exist
# but NOT how they work. Child classes must provide the implementation.
# Use the 'abc' module (Abstract Base Classes).

from abc import ABC, abstractmethod

class Payment(ABC):           # ABC makes it abstract
    @abstractmethod
    def pay(self, amount):    # abstract method — must be overridden
        pass

    @abstractmethod
    def refund(self, amount):
        pass

    def receipt(self, amount):   # concrete method — shared by all
        print(f"Receipt: ₹{amount} transaction processed.")


class CreditCard(Payment):
    def pay(self, amount):
        print(f"Paid ₹{amount} via Credit Card.")

    def refund(self, amount):
        print(f"₹{amount} refunded to Credit Card.")


class UPI(Payment):
    def pay(self, amount):
        print(f"Paid ₹{amount} via UPI.")

    def refund(self, amount):
        print(f"₹{amount} refunded to UPI.")


# payment = Payment()   # ❌ TypeError — cannot instantiate abstract class

cc  = CreditCard()
upi = UPI()

cc.pay(500)         # Paid ₹500 via Credit Card.
cc.receipt(500)     # Receipt: ₹500 transaction processed.
upi.pay(200)        # Paid ₹200 via UPI.
upi.refund(200)     # ₹200 refunded to UPI.


# =============================================================================
# 9. MAGIC / DUNDER METHODS
# =============================================================================
# Dunder = Double UNDERscore  (__method__)
# These are special methods Python calls automatically in certain situations.

class Book:
    def __init__(self, title, author, pages):
        self.title  = title
        self.author = author
        self.pages  = pages

    def __str__(self):
        # Called by print() and str() — human-readable representation
        return f"'{self.title}' by {self.author}"

    def __repr__(self):
        # Called in the interpreter / for debugging
        return f"Book(title='{self.title}', author='{self.author}', pages={self.pages})"

    def __len__(self):
        # Called by len()
        return self.pages

    def __eq__(self, other):
        # Called by ==
        return self.title == other.title and self.author == other.author

    def __lt__(self, other):
        # Called by <  (allows sorting)
        return self.pages < other.pages

    def __add__(self, other):
        # Called by +  (combine two books into one collection)
        return f"Combined: {self.title} + {other.title}"


b1 = Book("Python Basics",    "Yash",  350)
b2 = Book("Advanced Python",  "Yash",  520)
b3 = Book("Python Basics",    "Yash",  350)

print(b1)            # 'Python Basics' by Yash     ← __str__
print(repr(b1))      # Book(title='Python Basics', ...) ← __repr__
print(len(b1))       # 350                          ← __len__
print(b1 == b3)      # True                         ← __eq__
print(b1 == b2)      # False
print(b1 < b2)       # True  (350 < 520)            ← __lt__
print(b1 + b2)       # Combined: Python Basics + Advanced Python

# Sorting uses __lt__ automatically
library = [b2, b1, Book("Django Guide", "Rohit", 410)]
library.sort()
for book in library:
    print(book, "-", len(book), "pages")


