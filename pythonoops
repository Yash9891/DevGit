# Q1. Create a class Rectangle with length and width.
#     Add methods: area(), perimeter(), is_square().
# ------ Solution ------
class Rectangle:
    def __init__(self, length, width):
        self.length = length
        self.width  = width

    def area(self):
        return self.length * self.width

    def perimeter(self):
        return 2 * (self.length + self.width)

    def is_square(self):
        return self.length == self.width

