# Write many rows at once using writerows() with a list of lists
print("\n--- writerows(): write all rows at once ---")

all_students = [
    ["name", "age", "marks", "grade"],   # header
    ["Vikram", 23, 95, "A+"],
    ["Sneha",  21, 72, "A"],
